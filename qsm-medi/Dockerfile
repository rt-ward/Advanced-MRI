FROM ubuntu:18.04
ENV LD_LIBRARY_PATH="$LD_LIBRARY_PATH:/usr/lib/x86_64-linux-gnu:/opt/MCR-2018b/v95/runtime/glnxa64:/opt/MCR-2018b/v95/bin/glnxa64:/opt/MCR-2018b/v95/sys/os/glnxa64:/opt/MCR-2018b/v95/extern/bin/glnxa64" \
